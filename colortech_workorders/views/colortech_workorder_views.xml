<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista Lista de Órdenes de Trabajo -->
    <record id="colortech_workorder_view_tree" model="ir.ui.view">
        <field name="name">colortech.workorder.tree</field>
        <field name="model">colortech.workorder</field>
        <field name="arch" type="xml">
            <list string="Órdenes de Trabajo" open_form_view="True">
                <field name="name"/>
                <field name="date_received"/>
                <field name="client_name"/>
                <field name="device_type_id"/>
                <field name="device_brand"/>
                <field name="device_model"/>
                <field name="technician_name"/>
                <field name="total_cost"/>
                <field name="date_promised"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'entregado'"
                       decoration-info="state == 'recibido'"
                       decoration-warning="state == 'secado'"
                       decoration-danger="state == 'cancelado'"/>
            </list>
        </field>
    </record>

    <!-- Vista Formulario de Órdenes de Trabajo -->
    <record id="colortech_workorder_view_form" model="ir.ui.view">
        <field name="name">colortech.workorder.form</field>
        <field name="model">colortech.workorder</field>
        <field name="arch" type="xml">
            <form string="Orden de Trabajo">
                <header>
                    <button name="action_en_proceso" type="object"
                            string="Iniciar Trabajo" class="oe_highlight"
                            invisible="state != 'recibido'"/>
                    <button name="action_secado" type="object"
                            string="Poner a Secar" class="oe_highlight"
                            invisible="state != 'en_proceso'"/>
                    <button name="action_control" type="object"
                            string="Control de Calidad" class="oe_highlight"
                            invisible="state != 'secado'"/>
                    <button name="action_terminado" type="object"
                            string="Marcar Terminado" class="oe_highlight"
                            invisible="state != 'control'"/>
                    <button name="action_entregado" type="object"
                            string="Entregar al Cliente" class="oe_highlight"
                            invisible="state != 'terminado'"/>
                    <button name="action_cancelar" type="object"
                            string="Cancelar" class="btn-secondary"
                            invisible="state in ('entregado', 'cancelado')"/>
                    <button name="action_reabrir" type="object"
                            string="Reabrir" class="btn-secondary"
                            invisible="state != 'cancelado'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="recibido,en_proceso,secado,control,terminado,entregado"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Datos del Cliente">
                            <field name="client_name"/>
                            <field name="client_phone"/>
                            <field name="client_email"/>
                        </group>
                        <group string="Asignación y Fechas">
                            <field name="technician_name"/>
                            <field name="priority"/>
                            <field name="date_received"/>
                            <field name="date_promised"/>
                            <field name="date_delivered"
                                   invisible="state != 'entregado'"/>
                        </group>
                    </group>
                    <group>
                        <group string="Dispositivo">
                            <field name="device_type_id"/>
                            <field name="device_brand"/>
                            <field name="device_model"/>
                            <field name="device_serial"/>
                            <field name="device_condition"/>
                        </group>
                        <group string="Resumen">
                            <field name="service_count"/>
                            <field name="total_hours"/>
                            <field name="total_cost"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Servicios" name="services">
                            <field name="line_ids">
                                <list string="Servicios" editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="service_id"/>
                                    <field name="description"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                    <field name="estimated_hours"/>
                                    <field name="subtotal"/>
                                </list>
                            </field>
                        </page>
                        <page string="Observaciones del Dispositivo"
                              name="device_notes">
                            <field name="device_notes"
                                   placeholder="Describe el estado del dispositivo, arañazos, golpes, etc."/>
                        </page>
                        <page string="Notas Internas" name="notes">
                            <field name="notes"
                                   placeholder="Notas internas del taller..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Vista Búsqueda -->
    <record id="colortech_workorder_view_search" model="ir.ui.view">
        <field name="name">colortech.workorder.search</field>
        <field name="model">colortech.workorder</field>
        <field name="arch" type="xml">
            <search string="Buscar Órdenes">
                <field name="name"/>
                <field name="client_name"/>
                <field name="device_brand"/>
                <field name="technician_name"/>
                <filter name="filter_recibido" string="Recibidos"
                        domain="[('state', '=', 'recibido')]"/>
                <filter name="filter_en_proceso" string="En Proceso"
                        domain="[('state', '=', 'en_proceso')]"/>
                <filter name="filter_terminado" string="Terminados"
                        domain="[('state', '=', 'terminado')]"/>
                <separator/>
                <filter name="group_state" string="Estado"
                        context="{'group_by': 'state'}"/>
                <filter name="group_technician" string="Técnico"
                        context="{'group_by': 'technician_name'}"/>
                <filter name="group_device" string="Tipo Dispositivo"
                        context="{'group_by': 'device_type_id'}"/>
            </search>
        </field>
    </record>

    <!-- Secuencia automática para nº de orden -->
    <record id="seq_colortech_workorder" model="ir.sequence">
        <field name="name">Secuencia Órdenes ColorTech</field>
        <field name="code">colortech.workorder</field>
        <field name="prefix">OT-</field>
        <field name="padding">4</field>
        <field name="number_increment">1</field>
    </record>

    <!-- Acción -->
    <record id="colortech_workorder_action" model="ir.actions.act_window">
        <field name="name">Órdenes de Trabajo</field>
        <field name="res_model">colortech.workorder</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'no_preview': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea tu primera orden de trabajo
            </p>
            <p>Registra dispositivos de clientes y gestiona el flujo
            de trabajo del taller.</p>
        </field>
    </record>

</odoo>
