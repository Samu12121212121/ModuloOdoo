<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista Lista de Servicios -->
    <record id="colortech_service_view_tree" model="ir.ui.view">
        <field name="name">colortech.service.tree</field>
        <field name="model">colortech.service</field>
        <field name="arch" type="xml">
            <list string="Servicios">
                <field name="code"/>
                <field name="name"/>
                <field name="service_type"/>
                <field name="default_price"/>
                <field name="estimated_hours"/>
            </list>
        </field>
    </record>

    <!-- Vista Formulario de Servicios -->
    <record id="colortech_service_view_form" model="ir.ui.view">
        <field name="name">colortech.service.form</field>
        <field name="model">colortech.service</field>
        <field name="arch" type="xml">
            <form string="Servicio">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre del servicio"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Información">
                            <field name="code"/>
                            <field name="service_type"/>
                            <field name="active"/>
                        </group>
                        <group string="Tarifa">
                            <field name="default_price"/>
                            <field name="estimated_hours"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"
                               placeholder="Descripción del servicio..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista Búsqueda -->
    <record id="colortech_service_view_search" model="ir.ui.view">
        <field name="name">colortech.service.search</field>
        <field name="model">colortech.service</field>
        <field name="arch" type="xml">
            <search string="Buscar Servicios">
                <field name="name"/>
                <field name="code"/>
                <field name="service_type"/>
                <filter name="group_type" string="Tipo de Servicio"
                        context="{'group_by': 'service_type'}"/>
            </search>
        </field>
    </record>

    <!-- Acción -->
    <record id="colortech_service_action" model="ir.actions.act_window">
        <field name="name">Servicios</field>
        <field name="res_model">colortech.service</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea tu primer servicio
            </p>
            <p>Define los servicios que ofrece el taller con precios y tiempos.</p>
        </field>
    </record>

</odoo>
